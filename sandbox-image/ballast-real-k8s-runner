#!/usr/bin/env python3
"""Real Kubernetes CrashLoopBackOff runner for Ballast.

This runner intentionally keeps the same JSON-line protocol as mock-opencode:
it emits reason/tool events over stdout and waits for one policy decision line
from harness-agent before executing every command.

Unlike mock-opencode, command output is produced by real kubectl calls against
the kubeconfig mounted into the sandbox.
"""

from __future__ import annotations

import json
import os
import shlex
import subprocess
import sys
from pathlib import Path


VERSION = "0.1.0"


def env(name: str, fallback: str) -> str:
    return os.environ.get(name, "").strip() or fallback


NAMESPACE = env("BALLAST_TARGET_NAMESPACE", "ballast-demo")
SELECTOR = env("BALLAST_TARGET_SELECTOR", "app=crashloop-demo")
DEPLOYMENT = env("BALLAST_TARGET_DEPLOYMENT", "crashloop-demo")
FIX_CONFIGMAP = env("BALLAST_FIX_CONFIGMAP", "crashloop-demo-config")
FIX_PATH = Path("/tmp/ballast-k8s-fix.yaml")


def emit(event_type: str, properties: dict) -> None:
    print(
        json.dumps(
            {"type": event_type, "properties": properties},
            ensure_ascii=False,
            separators=(",", ":"),
        ),
        flush=True,
    )


def reason(index: int, title: str, thought: str) -> None:
    emit("reason.step", {"index": index, "title": title, "thought": thought})


def wait_decision() -> str:
    line = sys.stdin.readline()
    if not line:
        return "DENY"
    return line.strip().upper()


def run_tool(args: list[str], timeout_seconds: int = 60) -> bool:
    command = shlex.join(args)
    emit("tool.call", {"tool": "bash", "command": command})
    decision = wait_decision()
    if decision != "APPROVE":
        emit(
            "tool.result",
            {
                "command": command,
                "decision": decision or "DENY",
                "exit_code": None,
                "stdout": "",
                "stderr": "blocked by Ballast policy",
            },
        )
        return False

    try:
        completed = subprocess.run(
            args,
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=timeout_seconds,
        )
    except subprocess.TimeoutExpired as exc:
        stdout = exc.stdout or ""
        stderr = (exc.stderr or "") + f"\ncommand timed out after {timeout_seconds}s"
        emit(
            "tool.result",
            {
                "command": command,
                "decision": "APPROVE",
                "exit_code": 124,
                "stdout": stdout,
                "stderr": stderr.strip(),
            },
        )
        emit("error", {"message": f"command timed out: {command}"})
        return False

    emit(
        "tool.result",
        {
            "command": command,
            "decision": "APPROVE",
            "exit_code": completed.returncode,
            "stdout": completed.stdout,
            "stderr": completed.stderr,
        },
    )
    if completed.returncode != 0:
        emit(
            "error",
            {
                "message": "kubectl command failed",
                "command": command,
                "exit_code": completed.returncode,
            },
        )
        return False
    return True


def selector_labels() -> dict[str, str]:
    labels: dict[str, str] = {}
    for item in SELECTOR.split(","):
        key, sep, value = item.strip().partition("=")
        if sep and key and value:
            labels[key] = value
    if not labels:
        labels["app"] = DEPLOYMENT
    return labels


def yaml_labels(labels: dict[str, str], indent: int) -> str:
    prefix = " " * indent
    return "\n".join(f"{prefix}{key}: {value}" for key, value in sorted(labels.items()))


def write_fix_manifest() -> None:
    labels = selector_labels()
    manifest = f"""apiVersion: v1
kind: ConfigMap
metadata:
  name: {FIX_CONFIGMAP}
  namespace: {NAMESPACE}
data:
  APP_CONFIG_READY: "true"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {DEPLOYMENT}
  namespace: {NAMESPACE}
  labels:
{yaml_labels(labels, 4)}
spec:
  strategy:
    type: Recreate
  replicas: 1
  selector:
    matchLabels:
{yaml_labels(labels, 6)}
  template:
    metadata:
      labels:
{yaml_labels(labels, 8)}
    spec:
      containers:
        - name: app
          image: busybox:1.36
          imagePullPolicy: IfNotPresent
          command:
            - sh
            - -c
            - |
              if [ "$APP_CONFIG_READY" != "true" ]; then
                echo "Error: configmap {FIX_CONFIGMAP} not ready"
                exit 1
              fi
              echo "config loaded; app is healthy"
              sleep 3600
          env:
            - name: APP_CONFIG_READY
              valueFrom:
                configMapKeyRef:
                  name: {FIX_CONFIGMAP}
                  key: APP_CONFIG_READY
"""
    FIX_PATH.write_text(manifest, encoding="utf-8")


def main() -> int:
    emit(
        "server.connected",
        {
            "server": "ballast-real-k8s-runner",
            "version": VERSION,
            "namespace": NAMESPACE,
            "selector": SELECTOR,
            "deployment": DEPLOYMENT,
        },
    )

    reason(1, "读取真实 Pod 现场", "通过 kubectl 访问真实 Kubernetes API，确认目标 Pod 状态。")
    if not run_tool(["kubectl", "get", "pods", "-n", NAMESPACE, "-l", SELECTOR, "-o", "wide"]):
        return 1

    reason(2, "抓取真实容器日志", "读取 CrashLoopBackOff 容器日志，寻找启动失败信号。")
    if not run_tool(
        [
            "kubectl",
            "logs",
            "-n",
            NAMESPACE,
            "-l",
            SELECTOR,
            "--all-containers=true",
            "--tail=80",
            "--prefix=true",
        ]
    ):
        return 1

    reason(3, "检查 Deployment 配置", "读取 Deployment 当前声明式配置，确认修复对象。")
    if not run_tool(["kubectl", "describe", "deployment", DEPLOYMENT, "-n", NAMESPACE]):
        return 1

    write_fix_manifest()
    reason(
        4,
        "生成修复并等待审批",
        "修复文件已写入沙箱 /tmp；kubectl apply 是写操作，必须由 Ballast 人工审批后才执行。",
    )
    if not run_tool(["kubectl", "apply", "-f", str(FIX_PATH)]):
        return 1

    reason(5, "验证修复 rollout", "审批后的写操作已执行，继续用只读命令等待 Deployment 可用。")
    if not run_tool(
        [
            "kubectl",
            "wait",
            "--for=condition=available",
            f"deployment/{DEPLOYMENT}",
            "-n",
            NAMESPACE,
            "--timeout=90s",
        ],
        timeout_seconds=120,
    ):
        return 1

    if not run_tool(["kubectl", "get", "pods", "-n", NAMESPACE, "-l", SELECTOR, "-o", "wide"]):
        return 1

    emit(
        "message.completed",
        {
            "role": "assistant",
            "text": f"真实 Kubernetes 场景已完成：{NAMESPACE}/{DEPLOYMENT} 经审批后完成修复并通过可用性验证。",
        },
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
