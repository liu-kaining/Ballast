#!/usr/bin/env python3
"""
mock-opencode: v0.1 占位实现，模拟 `opencode serve --format json` 的最小行为。
真实 OpenCode 引擎接入留待 v0.2（见 docs/opencode-protocol-research.md）。

端点：
  GET  /doc                       -> 占位 OpenAPI 3.1 spec
  POST /session                   -> 创建会话，返回 session id
  POST /session/{id}/message      -> 接受消息，返回 AssistantMessage
  GET  /event                     -> SSE 事件流（吐预设 Reason Tree 步骤 + 一条 kubectl apply 触发灰名单）
  POST /mcp                       -> 动态注入 MCP（占位）
"""
import json
import sys
import time
import uuid
import threading
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 4096

# 预设的 Reason Tree 步骤剧本：模拟一次 K8s CrashLoopBackOff 排障，
# 最后吐出一条 `kubectl apply` 触发灰名单拦截。
SCRIPTED_EVENTS = [
    {"type": "server.connected", "properties": {"server": "mock-opencode", "version": "0.1.0"}},
    {"type": "reason.step", "properties": {"index": 1, "title": "列出异常 Pod", "thought": "执行 kubectl get pods 抓取 CrashLoopBackOff 现场"}},
    {"type": "tool.call", "properties": {"tool": "bash", "command": "kubectl get pods -n prod", "stdout": "my-app-7b6f4-xz  0/1  CrashLoopBackOff  12  3m"}},
    {"type": "reason.step", "properties": {"index": 2, "title": "捞取日志", "thought": "kubectl logs 找根因"}},
    {"type": "tool.call", "properties": {"tool": "bash", "command": "kubectl logs my-app-7b6f4-xz -n prod", "stdout": "Error: configmap my-app-config not found"}},
    {"type": "reason.step", "properties": {"index": 3, "title": "拟修复并应用", "thought": "生成修复 cm 并 kubectl apply 自愈"}},
    {"type": "tool.call", "properties": {"tool": "bash", "command": "kubectl apply -f fixed_cm.yaml", "stdout": ""}},
    {"type": "message.completed", "properties": {"role": "assistant", "text": "已尝试自愈，等待审批放行。"}},
]

EVENT_SUBSCRIBERS = []  # list of list[str] queues
SUBSCRIBERS_LOCK = threading.Lock()


def enqueue_event(event):
    payload = json.dumps(event, ensure_ascii=False)
    with SUBSCRIBERS_LOCK:
        for q in EVENT_SUBSCRIBERS:
            q.append(payload)


def scripted_loop():
    for ev in SCRIPTED_EVENTS:
        enqueue_event(ev)
        time.sleep(1.5)
    # 之后保持连接，周期性发心跳，便于前端持续渲染
    i = 0
    while True:
        time.sleep(10)
        i += 1
        enqueue_event({"type": "heartbeat", "properties": {"seq": i}})


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        sys.stderr.write("[mock-opencode] " + (fmt % args) + "\n")

    def _send_json(self, code, body):
        data = json.dumps(body, ensure_ascii=False).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        if self.path == "/doc":
            self._send_json(200, {
                "openapi": "3.1.0",
                "info": {"title": "mock-opencode", "version": "0.1.0"},
                "paths": {
                    "/session": {"post": {"summary": "create session"}},
                    "/session/{id}/message": {"post": {"summary": "send message"}},
                    "/event": {"get": {"summary": "SSE event stream"}},
                    "/mcp": {"post": {"summary": "inject mcp server"}},
                },
            })
            return
        if self.path == "/event":
            self._handle_sse()
            return
        self._send_json(404, {"error": "not found"})

    def do_POST(self):
        length = int(self.headers.get("Content-Length", "0") or "0")
        raw = self.rfile.read(length) if length > 0 else b""
        try:
            payload = json.loads(raw.decode("utf-8")) if raw else {}
        except Exception:
            payload = {}

        if self.path == "/session":
            sid = str(uuid.uuid4())
            self._send_json(200, {"id": sid, "title": payload.get("title", "untitled")})
            return
        if self.path.startswith("/session/") and self.path.endswith("/message"):
            self._send_json(200, {
                "id": str(uuid.uuid4()),
                "role": "assistant",
                "parts": [{"type": "text", "text": "mock response"}],
            })
            return
        if self.path == "/mcp":
            self._send_json(200, {"name": payload.get("name", "unknown"), "status": "connected"})
            return
        self._send_json(404, {"error": "not found"})

    def _handle_sse(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "keep-alive")
        self.end_headers()
        queue = []
        with SUBSCRIBERS_LOCK:
            EVENT_SUBSCRIBERS.append(queue)
        try:
            # 先发首事件确保客户端立即收到 200 + stream
            self.wfile.write("event: server.connected\ndata: %s\n\n" % json.dumps({"server": "mock-opencode"}))
            self.wfile.flush()
            while True:
                if queue:
                    payload = queue.pop(0)
                    evt_type = "message"
                    # 简化：统一用 message 事件，data 内含 type 字段
                    self.wfile.write("event: %s\ndata: %s\n\n" % (evt_type, payload))
                    self.wfile.flush()
                else:
                    time.sleep(0.2)
        except (BrokenPipeError, ConnectionResetError):
            pass
        finally:
            with SUBSCRIBERS_LOCK:
                if queue in EVENT_SUBSCRIBERS:
                    EVENT_SUBSCRIBERS.remove(queue)


def main():
    t = threading.Thread(target=scripted_loop, daemon=True)
    t.start()
    srv = ThreadingHTTPServer(("0.0.0.0", PORT), Handler)
    print(f"[mock-opencode] listening on :{PORT}", file=sys.stderr)
    srv.serve_forever()


if __name__ == "__main__":
    main()
