#!/usr/bin/env python3
"""Deterministic v0.1 OpenCode substitute.

The default ``script`` mode speaks JSON lines over a PTY. Every tool call waits
for an APPROVE or DENY line from harness-agent before producing a result. A
small ``serve`` mode remains available for protocol/client development.
"""

import argparse
import json
import sys
import time
import uuid
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer


def emit(event_type, properties):
    print(
        json.dumps(
            {"type": event_type, "properties": properties},
            ensure_ascii=False,
            separators=(",", ":"),
        ),
        flush=True,
    )


def gated_tool_call(command, simulated_stdout):
    emit("tool.call", {"tool": "bash", "command": command})
    decision = sys.stdin.readline().strip().upper()
    if decision != "APPROVE":
        emit(
            "tool.result",
            {
                "command": command,
                "decision": "DENY",
                "stdout": "",
                "stderr": "blocked by Ballast policy",
            },
        )
        return False
    emit(
        "tool.result",
        {
            "command": command,
            "decision": "APPROVE",
            "stdout": simulated_stdout,
            "stderr": "",
        },
    )
    return True


def run_script():
    emit("server.connected", {"server": "mock-opencode", "version": "0.1.0"})

    emit(
        "reason.step",
        {
            "index": 1,
            "title": "列出异常 Pod",
            "thought": "执行 kubectl get pods 抓取 CrashLoopBackOff 现场",
        },
    )
    if not gated_tool_call(
        "kubectl get pods -n prod",
        "my-app-7b6f4-xz  0/1  CrashLoopBackOff  12  3m",
    ):
        return

    emit(
        "reason.step",
        {"index": 2, "title": "捞取日志", "thought": "kubectl logs 找根因"},
    )
    if not gated_tool_call(
        "kubectl logs my-app-7b6f4-xz -n prod",
        "Error: configmap my-app-config not found",
    ):
        return

    emit(
        "reason.step",
        {
            "index": 3,
            "title": "拟修复并应用",
            "thought": "生成修复 ConfigMap；写操作交由 Ballast 等待人工审批",
        },
    )
    if not gated_tool_call(
        "kubectl apply -f fixed_cm.yaml",
        "configmap/my-app-config configured",
    ):
        return

    emit(
        "message.completed",
        {"role": "assistant", "text": "自愈变更已审批并完成，沙箱可以销毁。"},
    )


PREVIEW_EVENTS = [
    {"type": "server.connected", "properties": {"server": "mock-opencode", "version": "0.1.0"}},
    {
        "type": "reason.step",
        "properties": {
            "index": 1,
            "title": "列出异常 Pod",
            "thought": "执行 kubectl get pods 抓取 CrashLoopBackOff 现场",
        },
    },
    {
        "type": "tool.call",
        "properties": {"tool": "bash", "command": "kubectl get pods -n prod"},
    },
]


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        sys.stderr.write("[mock-opencode] " + (fmt % args) + "\n")

    def _send_json(self, code, body):
        data = json.dumps(body, ensure_ascii=False).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        if self.path == "/doc":
            self._send_json(
                200,
                {
                    "openapi": "3.1.0",
                    "info": {"title": "mock-opencode", "version": "0.1.0"},
                    "paths": {
                        "/session": {"post": {"summary": "create session"}},
                        "/session/{id}/message": {"post": {"summary": "send message"}},
                        "/event": {"get": {"summary": "SSE event stream"}},
                        "/mcp": {"post": {"summary": "inject mcp server"}},
                    },
                },
            )
            return
        if self.path == "/event":
            self._handle_sse()
            return
        self._send_json(404, {"error": "not found"})

    def do_POST(self):
        length = int(self.headers.get("Content-Length", "0") or "0")
        raw = self.rfile.read(length) if length > 0 else b""
        try:
            payload = json.loads(raw.decode("utf-8")) if raw else {}
        except ValueError:
            self._send_json(400, {"error": "invalid json"})
            return

        if self.path == "/session":
            self._send_json(201, {"id": str(uuid.uuid4()), "title": payload.get("title", "untitled")})
            return
        if self.path.startswith("/session/") and self.path.endswith("/message"):
            self._send_json(
                200,
                {
                    "id": str(uuid.uuid4()),
                    "role": "assistant",
                    "parts": [{"type": "text", "text": "mock response"}],
                },
            )
            return
        if self.path == "/mcp":
            self._send_json(200, {"name": payload.get("name", "unknown"), "status": "connected"})
            return
        self._send_json(404, {"error": "not found"})

    def _handle_sse(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.end_headers()
        try:
            for event in PREVIEW_EVENTS:
                data = json.dumps(event, ensure_ascii=False)
                frame = f"event: {event['type']}\ndata: {data}\n\n".encode("utf-8")
                self.wfile.write(frame)
                self.wfile.flush()
                time.sleep(0.05)
        except (BrokenPipeError, ConnectionResetError):
            return


def serve(port):
    server = ThreadingHTTPServer(("0.0.0.0", port), Handler)
    print(f"[mock-opencode] listening on :{port}", file=sys.stderr)
    server.serve_forever()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--mode", choices=("script", "serve"), default="script")
    parser.add_argument("--port", type=int, default=4096)
    args = parser.parse_args()
    if args.mode == "serve":
        serve(args.port)
    else:
        run_script()


if __name__ == "__main__":
    main()
